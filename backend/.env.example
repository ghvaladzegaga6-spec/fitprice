NODE_ENV=production
PORT=4000

# Database - შეცვალე შენი PostgreSQL URL-ით
DATABASE_URL=postgresql://fitprice_user:STRONG_PASSWORD_HERE@localhost:5432/fitprice_db

# JWT - გაუშვი: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_BYTE_RANDOM_HEX

# Python service
PYTHON_SERVICE_URL=http://python-service:8000
INTERNAL_TOKEN=REPLACE_WITH_STRONG_RANDOM_TOKEN

# OpenAI
OPENAI_API_KEY=sk-...your-key-here...

# CORS - Frontend URL
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Logging
LOG_LEVEL=info
