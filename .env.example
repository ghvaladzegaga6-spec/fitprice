# ════════════════════════════════════════
#  FITPRICE — Production Environment
#  ⚠️  ასლი: .env (ამ ფაილს git-ში ნუ ატვირთავ!)
# ════════════════════════════════════════

# Database password (შეცვალე!)
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_123!

# JWT Secrets — გენერაცია:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_STRING_HERE
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_BYTE_HEX_STRING

# Internal token (Backend <-> Python)
# გენერაცია: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_TOKEN=REPLACE_WITH_32_BYTE_HEX_STRING

# OpenAI API key
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# Your domain (Vercel URL ან საკუთარი)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
